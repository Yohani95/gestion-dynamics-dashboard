# Copia a .env.local y rellena con las credenciales de SQL Server (TheLineGroup).
# SQL_USER y SQL_PASSWORD son obligatorios.
# Si la contraseña tiene # o &, usa comillas dobles. Si tiene $, escápalo: "clave\$con\$pesos"

# Servidor: nombre (SRV_VENTAS) o IP (192.30.1.26).
# Puerto: usa SQL_PORT o el formato "IP,puerto" (ej. 192.30.1.23,49143); no mezcles ambos para el mismo host.
SQL_SERVER=SRV_VENTAS
SQL_DATABASE=Gestion
SQL_USER=tu_usuario
SQL_PASSWORD=tu_password

#andpac conexion
SQL_SERVER_andpac=SRV-andpac
SQL_DATABASE_andpac=Gestion
SQL_USER_andpac=username
SQL_PASSWORD_andpac=password

#tecnobuy conexion
SQL_SERVER_tecnobuy=192.30.1.26
SQL_DATABASE_tecnobuy=Gestion
SQL_USER_tecnobuy=tu_usuario
SQL_PASSWORD_tecnobuy=tu_password

#data warehouse dev2 conexion (solo jobs)
SQL_SERVER_dwhdev2=dev2-srv
SQL_DATABASE_dwhdev2=msdb
SQL_USER_dwhdev2=tu_usuario
SQL_PASSWORD_dwhdev2=tu_password

# Opcional: puerto (por defecto 1433)
# SQL_PORT=1433

# Por defecto la conexión es sin SSL (evita error SSL en servidores on-prem).
# Si tu servidor exige TLS, pon SQL_ENCRYPT=true
# SQL_ENCRYPT=true

# Folder ERP - Id_Emisor por empresa (evita "Rut de Compañía incorrecto" al timbrar)
# Se obtiene del JSON/SP si está disponible; si no, usa estas variables:
# FOLDER_EMPRESA_ID=201          # TL / International
# FOLDER_EMPRESA_ID_CISA=202     # Comercializadora
# FOLDER_EMPRESA_ID_HIT=221
# FOLDER_EMPRESA_ID_NIKE=202
# FOLDER_EMPRESA_ID_andpac=326
# FOLDER_EMPRESA_ID_tecnobuy=191 # TecnoBuy / TB
#
# Mapeo por Cod_Empresa (GUID en Ges_Empresas) → Empresa_ID en Folder. Usar si Folder devuelve
# "Rut de Compañía incorrecto" (el XML trae un RUT y el header debe ser la empresa correcta en Folder).
# FOLDER_EMPRESA_IDS_JSON={"107bf720-2b02-4a89-8bcf-796cba00439f":"NUMERO_FOLDER"}

# Dynamics 365 OData (OAuth2 client_credentials, como en Postman)
# Token: https://login.microsoftonline.com/{tenant}/oauth2/v2.0/token
# Body: grant_type=client_credentials, client_id, client_secret, scope={url-d365}/.default
# Si client_secret tiene $ usar comillas y escapar: "secreto\$con\$pesos"
#
# Business Central API v2.0 (mismo flujo que Ges_EnviaVenta_Dyn):
# DYNAMICS_TOKEN_URL=https://login.microsoftonline.com/TU-TENANT-ID/oauth2/v2.0/token
# DYNAMICS_CLIENT_ID=tu-client-id
# DYNAMICS_CLIENT_SECRET=tu-client-secret
# DYNAMICS_SCOPE=https://api.businesscentral.dynamics.com/.default
# DYNAMICS_BC_TENANT_ID=TU-TENANT
# DYNAMICS_BC_ENVIRONMENT=Production
# Id empresa BC: se resuelve desde Ges_Empresas.Id_Dynamics por Cod_Empresa
# DYNAMICS_ODATA_SALES_ENTITY=salesInvoices
# DYNAMICS_ODATA_CREDIT_ENTITY=salesCreditMemos
# DYNAMICS_ODATA_SALES_FILTER_FIELD=number
# Folio BC: BLE=39-{nro}, FCV=33-{nro}, NCV=61-{nro}
#
# Finance & Operations (F&O):
# DYNAMICS_SCOPE=https://tu-entorno.operations.dynamics.com/.default
# DYNAMICS_ODATA_BASE_URL=https://tu-entorno.operations.dynamics.com/data
# DYNAMICS_ODATA_SALES_ENTITY=SalesInvoiceHeadersV2
# DYNAMICS_ODATA_SALES_FILTER_FIELD=InvoiceId

# Auth temporal de administradores (V1)
# local: usa usuarios definidos en ADMIN_USERS_JSON y sesion en cookie httpOnly
AUTH_PROVIDER=local
AUTH_SESSION_SECRET=CAMBIAR_ESTE_SECRETO_LARGO_Y_UNICO
ADMIN_USERS_JSON=[{"username":"admin1","passwordHash":"$2b$12$REEMPLAZAR_HASH","role":"ADMIN"},{"username":"admin2","passwordHash":"$2b$12$REEMPLAZAR_HASH","role":"ADMIN"},{"username":"admin3","passwordHash":"$2b$12$REEMPLAZAR_HASH","role":"ADMIN"}]

# Compatibilidad futura con Windows/IIS (no activa en V1)
# AUTH_PROVIDER=windows
# WINDOWS_ADMIN_USERS=DOMINIO\\usuario1,DOMINIO\\usuario2,DOMINIO\\usuario3
